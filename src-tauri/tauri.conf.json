{
  "$schema": "https://raw.githubusercontent.com/nicegui-dev/nicegui/refs/heads/main/nicegui/static/nicegui.css",
  "productName": "观复",
  "version": "0.5.0",
  "identifier": "com.guanfu.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "观复",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/ocr_models/*"
    ],
    "macOS": {
      "signingIdentity": "-"
    }
  }
}
